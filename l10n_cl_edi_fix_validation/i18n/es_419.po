#. module: l10n_cl_edi_fix_validation
#. odoo-python
#: code:l10n_cl_edi_fix_validation/models/account_move.py:0
msgid ""
"%(company_type)s %(partner)s has not a comune or city defined. This is "
"mandatory for electronic invoicing. Please edit the contact and set one."
msgstr ""
"%(company_type)s %(partner)s no tiene una comuna o ciudad definida. "
"Esto es mandatorio para facturación electrónica. Por favor edite el "
"contacto y establezca una."

#. module: l10n_cl_edi_fix_validation
#. odoo-python
#: code:l10n_cl_edi_fix_validation/models/account_move.py:0
msgid ""
"Your company has not a comune or city defined. This is mandatory for "
"electronic invoicing. Please go to your company data, and set the correct "
"one."
msgstr ""
"Su compañía no tiene una comuna o ciudad definida. Esto es mandatorio para "
"facturación electrónica. Por favor, vaya a la configuración de los datos "
"de su compañía y establezca la correcta."

