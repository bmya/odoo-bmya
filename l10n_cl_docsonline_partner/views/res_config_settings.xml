<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings" model="ir.ui.view">
        <field name="name">res.config.settings.docs.online.connect</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="l10n_cl.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='l10n_cl_section']" position="after">
                <block title="Connection to Documentos Online (documentosonline.cl)" id="l10n_cl_docs_online_partner"
                       invisible="country_code != 'CL'">
                    <setting string="Read Chilean partners data from documentosonline.cl"
                             help="Put here your free API token to get the fiscal data. Visit https://documentosonline.cl to register."
                             id="docs_online_1_settings">
                        <div class="content-group">
                            <div class="row">
                                <label string="Partners Token" for="docs_online_partner_token"
                                       class="col-lg-4 o_light_label"/>
                                <field name="docs_online_partner_token"/>
                            </div>
                        </div>
                    </setting>
                    <setting string="What to do if partner exists?"
                             help="Select if you want to replace data if the partner already exists in documentosonline.cl"
                             id="docs_online_2_settings">
                        <div class="content-group">
                            <div class="row">
                                <field name="docs_online_partner_replace_name" style="width: 10% !important;"/>
                                <label string="Replace Name" for="docs_online_partner_replace_name"
                                       class="col-lg-10 o_light_label"/>
                            </div>
                            <div class="row">
                                <field name="docs_online_partner_replace_street" style="width: 10% !important;"/>
                                <label string="Replace Address" for="docs_online_partner_replace_street"
                                       class="col-lg-10 o_light_label"/>
                            </div>
                            <div class="row">
                                <field name="docs_online_partner_replace_email" style="width: 10% !important;"/>
                                <label string="Replace Email" for="docs_online_partner_replace_email"
                                       class="col-lg-10 o_light_label"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
